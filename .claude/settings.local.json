{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "WebSearch",
      "WebFetch",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh search:*)",
      "Bash(gh api:*)",
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git stash:*)",
      "Bash(git ls-tree:*)",
      "Bash(npm run codegen:*)",
      "Bash(npx tsc:*)",
      "Bash(npx biome check:*)",
      "Bash(npm run biome:check:*)",
      "Bash(docker compose:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(which:*)",
      "Bash(pwd:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(mkdir:*)",
      "Bash(mkdir -p:*)",
      "Bash(xargs:*)",
      "Bash(* --version)",
      "Skill(code-review:code-review)",
      "Bash(gh repo view --json nameWithOwner,url)",
      "Bash(bash scripts/create_issues.sh)",
      "WebFetch(domain:registry.npmjs.org)",
      "Bash(pnpm add:*)",
      "Bash(pnpm install:*)",
      "WebFetch(domain:api.github.com)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "./.claude/statusline.sh",
    "padding": 0
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/setup-worktree.sh"
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory",
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowLocalBinding": true
    }
  }
}
