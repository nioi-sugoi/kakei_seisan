{
	"name": "api",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"dev": "[ -f ../.env.worktree ] && . ../.env.worktree; wrangler dev --ip 0.0.0.0 --port ${API_PORT:-8787} --persist-to $(git rev-parse --path-format=absolute --git-common-dir | xargs dirname)/.wrangler-shared",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit",
		"check": "biome check . && tsc --noEmit && vitest run",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply kakei-seisan-db --local --persist-to $(git rev-parse --path-format=absolute --git-common-dir | xargs dirname)/.wrangler-shared"
	},
	"dependencies": {
		"@better-auth/expo": "^1.5.2",
		"@hono/valibot-validator": "^0.6.0",
		"better-auth": "^1.5.2",
		"drizzle-orm": "^0.45.0",
		"hono": "^4.7.0",
		"resend": "^6.9.3",
		"valibot": "^1.0.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.13.2",
		"@cloudflare/workers-types": "^4.20250214.0",
		"better-sqlite3": "^12.6.2",
		"drizzle-kit": "^0.31.0",
		"typescript": "~5.9.2",
		"vitest": "^4.1.0",
		"wrangler": "^4.0.0"
	}
}
